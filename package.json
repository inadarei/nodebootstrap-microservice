{
  "name": "ms-nodebootstrap-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/server.js",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "start": "bun --watch src/server.js",
    "migrate": "bun src/migrate.js up",
    "migrate:down": "bun src/migrate.js down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "simple-git-hooks || true"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "umzug": "^3.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "ajv": "8",
    "eslint": "^9.17.0",
    "lint-staged": "^15.2.11",
    "msw": "^2.7.0",
    "neostandard": "^0.12.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "simple-git-hooks": "^2.11.1",
    "supertest": "^7.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
