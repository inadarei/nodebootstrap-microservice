# Copy to .env for local development. Never commit .env.
NODE_ENV=development
PORT=5501
LOG_LEVEL=info

# Use "localhost" for host-side commands (npm test, npm run migrate).
# docker compose overrides this to the DB service name inside the network.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=microservices_demo
POSTGRES_USER=microservices_demo
POSTGRES_PASSWORD=microservices_demo_pw
PG_POOL_MAX=20

BCRYPT_ROUNDS=12
